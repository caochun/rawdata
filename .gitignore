# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/

# Data files — belong in a separate data repo, not here
*.csv
schema.yaml
catalog.yaml
.loom_conflicts.json

# But example data is committed as reference
!example/**/*.csv
!example/**/schema.yaml
!example/**/catalog.yaml

# fox-crm converted schemas
!fox-crm/**/schema.yaml
!fox-crm/**/catalog.yaml

# fox-oms unified model
!fox-oms/schema.yaml
!fox-oms/catalog.yaml

# Hermes — only track our plugin and skill; ignore everything else
.hermes/*
!.hermes/plugins/
!.hermes/skills/
.hermes/skills/*
!.hermes/skills/loom/

# OS
.DS_Store
